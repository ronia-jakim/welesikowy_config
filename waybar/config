{
    "height": 30, // Waybar height (to be removed for auto height)
    //"spacing": 4, // Gaps between modules (4px)
    "modules-left": ["sway/workspaces", "custom/spotify", "custom/battery_management"],
    "modules-center": ["clock"],
    "modules-right": ["network", "bluetooth", "custom/sunpaper", "backlight", "pulseaudio", "battery", "custom/poweroff"],
    "clock": {
        "format": "{:%a %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d.%m.%Y}"
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ’Ś¦",
        "format-plugged": "{capacity}% ’ć”",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        "format-wifi": "’ć½",
        "format-ethernet": "{ipaddr}/{cidr} ’×¢",
        "tooltip-format": "{essid}",
